{
  "name": "lms-reltroner-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:next": "next dev --webpack",
    "contentlayer:build": "contentlayer build",
    "contentlayer:dev": "contentlayer dev",
    "build": "npm run contentlayer:build && npm run typecheck && npm run lint && npm run validate:content && npm run validate:resources && npm run check:orphans && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:content": "tsx scripts/validate-content.ts",
    "validate:resources": "tsx scripts/validate-resources.ts",
    "check:orphans": "tsx scripts/check-orphans.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "contentlayer": "^0.3.4",
    "next": "16.2.6",
    "oidc-client-ts": "^3.5.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "zod": "^4.4.3"
  }
}
